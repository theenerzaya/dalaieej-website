	<Placemark id="0263D7D4943CE7B6D0A1">
		<name>Official_Access_Road_Dalai_Eej_Resort_GPS_Trace</name>
		<description><![CDATA[<div><span style="font-style: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; text-align: start; text-indent: 0px; text-transform: none; white-space: normal; word-spacing: 0px; text-decoration: none; caret-color: rgb(0, 0, 0); color: rgb(0, 0, 0); float: none; display: inline;"><span class="size" style="font-size:medium">Please add the access road from the main road turnoff, through the gate,<span class="Apple-converted-space">&nbsp;</span></span></span><b style="font-style: normal; font-variant-caps: normal; letter-spacing: normal; text-align: start; text-indent: 0px; text-transform: none; white-space: normal; word-spacing: 0px; text-decoration: none; caret-color: rgb(0, 0, 0); color: rgb(0, 0, 0);">ending at the guest parking area</b><span style="font-style: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; text-align: start; text-indent: 0px; text-transform: none; white-space: normal; word-spacing: 0px; text-decoration: none; caret-color: rgb(0, 0, 0); color: rgb(0, 0, 0); float: none; display: inline;"><span class="size" style="font-size:medium">. Directions currently stop on the highway.</span></span><br></div>]]></description>
		<LookAt>
			<longitude>100.2323664785985</longitude>
			<latitude>50.46316058359585</latitude>
			<altitude>1731.711365180018</altitude>
